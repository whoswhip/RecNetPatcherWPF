<Window
  x:Class="RecNetPatcherWPF.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
  Title="RecNet Patcher"
  Width="500"
  Height="645"
  MinWidth="500"
  MaxWidth="500"
  MinHeight="420"
  ResizeMode="CanResize"
  WindowStartupLocation="CenterScreen"
  WindowStyle="None"
  AllowsTransparency="True"
  Background="Transparent"
>
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome
      CaptionHeight="48"
      ResizeBorderThickness="6"
      CornerRadius="12"
      GlassFrameThickness="0"
      UseAeroCaptionButtons="False"
    />
  </shell:WindowChrome.WindowChrome>

  <Grid x:Name="WindowClipHost" SizeChanged="WindowClipHost_SizeChanged">
    <Border Background="{StaticResource WindowBrush}" CornerRadius="12" />

    <Grid Margin="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="48" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border
        Grid.Row="0"
        Background="{StaticResource TitleBarBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="0,0,0,1"
        CornerRadius="11,11,0,0"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
      >
        <Grid>
          <TextBlock
            Text="RecNet Patcher"
            VerticalAlignment="Center"
            Margin="18,0,112,0"
            FontSize="13"
            FontWeight="SemiBold"
          />

          <StackPanel
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,8,0"
            Orientation="Horizontal"
            shell:WindowChrome.IsHitTestVisibleInChrome="True"
          >
            <Button
              Width="36"
              Height="32"
              Margin="0,0,4,0"
              Style="{StaticResource WindowButtonStyle}"
              Click="MinimizeButton_Click"
            >
              <Button.Tag>
                <CornerRadius TopLeft="8" TopRight="8" BottomRight="8" BottomLeft="8" />
              </Button.Tag>
              <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
            </Button>
            <Button
              Width="36"
              Height="32"
              Style="{StaticResource WindowButtonStyle}"
              Click="CloseButton_Click"
            >
              <Button.Tag>
                <CornerRadius TopLeft="8" TopRight="8" BottomRight="8" BottomLeft="8" />
              </Button.Tag>
              <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="10,24,10,10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="0,0,0,20">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="48" />
          </Grid.ColumnDefinitions>

          <Button
            x:Name="MetadataButton"
            Grid.Column="0"
            Content="Metadata"
            Style="{StaticResource ActionButtonStyle}"
            Click="ModeButton_Click"
          >
            <Button.Tag>
              <CornerRadius TopLeft="8" BottomLeft="8" />
            </Button.Tag>
          </Button>
          <Button
            x:Name="DllButton"
            Grid.Column="1"
            Content="DLL"
            Style="{StaticResource ActionButtonStyle}"
            Click="ModeButton_Click"
          >
            <Button.Tag>
              <CornerRadius />
            </Button.Tag>
          </Button>
          <Button
            x:Name="PhotonButton"
            Grid.Column="2"
            Content="Photon"
            Style="{StaticResource ActionButtonStyle}"
            Click="ModeButton_Click"
          >
            <Button.Tag>
              <CornerRadius />
            </Button.Tag>
          </Button>
          <Button
            x:Name="PresetsButton"
            Grid.Column="3"
            Style="{StaticResource ActionButtonStyle}"
            Click="PresetsButton_Click"
          >
            <Button.Tag>
              <CornerRadius TopRight="8" BottomRight="8" />
            </Button.Tag>
            <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="18" />
          </Button>
        </Grid>

        <StackPanel x:Name="EditorPanel" Grid.Row="2">
          <Border
            x:Name="DropZone"
            Height="126"
            AllowDrop="True"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Cursor="Hand"
            Drop="DropZone_Drop"
            DragOver="DropZone_DragOver"
            MouseLeftButtonUp="DropZone_MouseLeftButtonUp"
          >
            <StackPanel VerticalAlignment="Center" Margin="18,0">
              <TextBlock
                x:Name="InputTitle"
                Text="Drop input file here"
                HorizontalAlignment="Center"
                FontSize="16"
                FontWeight="SemiBold"
              />
              <TextBlock
                x:Name="InputPathText"
                Text="or click to browse"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"
                Margin="0,8,0,0"
                Foreground="{StaticResource MutedTextBrush}"
                FontSize="12"
              />
            </StackPanel>
          </Border>

          <StackPanel x:Name="UrlPanel" Margin="0,22,0,0">
            <Label Content="Replacement URL" />
            <TextBox x:Name="ReplacementUrlTextBox" Text="https://ns.rec.net" />
          </StackPanel>

          <StackPanel x:Name="PhotonPanel" Margin="0,22,0,0" Visibility="Collapsed">
            <Label Content="Replacement Photon ID - top" />
            <TextBox x:Name="PhotonTopTextBox" />
            <Label Content="Replacement Photon ID - bottom" Margin="0,14,0,0" />
            <TextBox x:Name="PhotonBottomTextBox" />
            <Label Content="Original Photon ID - top (optional)" Margin="0,14,0,0" />
            <TextBox x:Name="OriginalPhotonTopTextBox" />
            <Label Content="Original Photon ID - bottom (optional)" Margin="0,14,0,0" />
            <TextBox x:Name="OriginalPhotonBottomTextBox" />
          </StackPanel>

          <Button
            x:Name="PatchButton"
            Content="Patch"
            Margin="0,24,0,0"
            Height="44"
            Style="{StaticResource ActionButtonStyle}"
            Click="PatchButton_Click"
          >
            <Button.Tag>
              <CornerRadius TopLeft="8" TopRight="8" BottomRight="8" BottomLeft="8" />
            </Button.Tag>
          </Button>
        </StackPanel>

        <Grid x:Name="PresetsPanel" Grid.Row="2" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <ScrollViewer
            Grid.Row="0"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            CanContentScroll="False"
          >
            <StackPanel x:Name="PresetListPanel" />
          </ScrollViewer>

          <StackPanel Grid.Row="1" Margin="0,14,0,0" VerticalAlignment="Bottom">
            <Label Content="Preset name" />
            <TextBox x:Name="PresetNameTextBox" />
            <Button
              x:Name="CreatePresetButton"
              Content="Create Preset"
              Margin="0,14,0,0"
              Height="40"
              Style="{StaticResource ActionButtonStyle}"
              Click="CreatePresetButton_Click"
            >
              <Button.Tag>
                <CornerRadius TopLeft="8" TopRight="8" BottomRight="8" BottomLeft="8" />
              </Button.Tag>
            </Button>
          </StackPanel>
        </Grid>
      </Grid>
    </Grid>

    <Border
      BorderBrush="{StaticResource BorderBrush}"
      BorderThickness="1"
      CornerRadius="12"
      IsHitTestVisible="False"
    />
  </Grid>
</Window>
